# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ALL paths must be absolute (no ../ relative paths).
# ─────────────────────────────────────────────────────────────────────────────

# Environment
JACKKNIFE_ENV=development

# LLM Provider API Keys (only the one you're using)
LLM_API_KEY=your-api-key-here
# ANTHROPIC_API_KEY=sk-ant-...       # used by litellm automatically
# OPENAI_API_KEY=sk-...              # used by litellm automatically
# GOOGLE_API_KEY=...                 # Gemini

# Memory Store
MEMORY_PERSIST_DIR=/absolute/path/to/your/project/memory_db

# Storage
STORAGE_BASE_PATH=/absolute/path/to/your/project/files

# AWS (if using S3 storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Google Cloud (if using GCS storage)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Azure (if using Azure Blob storage)
# AZURE_STORAGE_CONNECTION_STRING=

# Database connections
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
# MONGODB_URI=mongodb://localhost:27017
# REDIS_URL=redis://localhost:6379
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
